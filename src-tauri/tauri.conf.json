{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "Forensic Disk Imager",
    "version": "0.1.14",
    "identifier": "com.forensic.imager",
    "build": {
        "frontendDist": "../frontend"
    },
    "app": {
        "withGlobalTauri": true,
        "windows": [
            {
                "title": "Forensic Disk Imager",
                "width": 1200,
                "height": 900,
                "resizable": true
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "resources": [
            "winpmem/*",
            "avml/*"
        ]
    }
}
